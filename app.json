{
  "expo": {
    "name": "Pomflix",
    "slug": "pomflix",
    "version": "1.1.0",
    "scheme": "pomflix",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0C"
    },
    "ios": {
      "buildNumber": "8",
      "supportsTablet": true,
      "bundleIdentifier": "com.pomflix.app",
      "infoPlist": {
        "UIRequiresFullScreen": true,
        "NSMicrophoneUsageDescription": "Pomflix does not use the microphone.",
        "NSCameraUsageDescription": "Pomflix does not use the camera.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "5c674527-36f7-498e-a7bf-41b1fb057fd5"
      },
      "router": {}
    },
    "owner": "jsparxx201"
  }
}
