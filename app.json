{
  "expo": {
    "name": "Pomflix",
    "slug": "pomflix",
    "version": "1.0.0",
    "scheme": "pomflix",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pomflix.app",
      "infoPlist": {
        "UIRequiresFullScreen": true,
        "NSMicrophoneUsageDescription": "Pomflix does not use the microphone.",
        "NSCameraUsageDescription": "Pomflix does not use the camera."
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-secure-store",
      "expo-image",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
