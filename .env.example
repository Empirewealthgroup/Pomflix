# Pomflix signup backend URL
# Local dev: your machine's LAN IP (e.g. http://192.168.1.42:3001)
# Production: your private server's URL (e.g. https://api.pomflix.com)
EXPO_PUBLIC_SIGNUP_API_URL=https://your-server-domain.com

# Shared secret — must match SIGNUP_SECRET in server/.env
# Generate with: openssl rand -base64 36
EXPO_PUBLIC_SIGNUP_SECRET=replace-with-your-secret
